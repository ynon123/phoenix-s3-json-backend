{
  "name": "phoenix-s3-json-backend",
  "version": "1.0.0",
  "description": "Small Node.js Lambda-style backend for uploading/downloading JSON to S3",
  "type": "commonjs",
  "scripts": {
    "test": "jest --runInBand",
    "upload:local": "node scripts/upload-local.js",
    "download:local": "node scripts/download-local.js",
    "package:lambda": "node scripts/package-lambda.js",
    "terraform:init": "terraform -chdir=terraform init",
    "terraform:plan": "npm run package:lambda && terraform -chdir=terraform plan",
    "terraform:apply": "npm run package:lambda && terraform -chdir=terraform apply",
    "terraform:destroy": "terraform -chdir=terraform destroy",
    "verify:aws": "node scripts/verify-api.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.884.0",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "jest": "^30.0.5",
    "js-yaml": "^4.1.0"
  }
}
